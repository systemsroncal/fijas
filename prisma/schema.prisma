// Esquema Prisma — WPS Admin (MySQL en cPanel localhost)
generator client {
  provider      = "prisma-client-js"
  // native = local; rhel = Vercel; debian = Netlify/otros
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  SUBSCRIBER
}

enum AiProvider {
  OPENAI
  GEMINI
  GROK
  DEEPSEEK
  OPENROUTER
  NVIDIA
  CLAUDE
  MISTRAL
  COHERE
}

enum ScrapingStatus {
  IDLE
  RUNNING
  SUCCESS
  ERROR
}

enum LogCategory {
  SCRAPING
  AUTH
  API_KEY
  ADMIN
  SYSTEM
}

enum AnalysisMode {
  MATCH
  ACCUMULATOR
  RANDOM
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(SUBSCRIBER)
  maxSessions   Int? // null = usar límite del rol en SessionControl
  deviceId      String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  apiKeys      ApiKey[]
  accumulators Accumulator[]
  analyses     Analysis[]

  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?  @db.Text
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expires])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ApiKey {
  id           String     @id @default(cuid())
  userId       String
  provider     AiProvider
  encryptedKey String     @db.Text
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  lastUsed     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("api_keys")
}

model ScrapingSource {
  id              String         @id @default(cuid())
  name            String         @unique
  slug            String         @unique
  baseUrl         String
  isActive        Boolean        @default(true)
  selectorsConfig Json?
  lastScraped     DateTime?
  scrapingStatus  ScrapingStatus @default(IDLE)
  lastError       String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  predictions ScrapedPrediction[]

  @@map("scraping_sources")
}

model Match {
  id        String   @id @default(cuid())
  matchKey  String   @unique // hash estable: date|home|away|league
  matchDate DateTime
  kickoff   String?
  league    String
  homeTeam  String
  awayTeam  String
  isLive    Boolean  @default(false)
  /// scheduled | live | finished — sync TheSportsDB / hora
  phase     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  predictions        ScrapedPrediction[]
  accumulatorMatches AccumulatorMatch[]
  analyses           Analysis[]

  @@index([matchDate])
  @@index([league])
  @@index([phase])
  @@map("matches")
}

model ScrapedPrediction {
  id         String   @id @default(cuid())
  sourceId   String
  matchId    String
  externalId String?
  betType    String // 1X2, OU, BTTS, etc.
  betChoice  String // 1, X, 2, Over 2.5, Yes...
  odds       Decimal? @db.Decimal(10, 3)
  oddsHome   Decimal? @db.Decimal(10, 3)
  oddsDraw   Decimal? @db.Decimal(10, 3)
  oddsAway   Decimal? @db.Decimal(10, 3)
  oddsOver   Decimal? @db.Decimal(10, 3)
  oddsUnder  Decimal? @db.Decimal(10, 3)
  oddsBttsYes Decimal? @db.Decimal(10, 3)
  oddsBttsNo  Decimal? @db.Decimal(10, 3)
  statsNote  String?  @db.Text
  scrapedAt  DateTime @default(now())
  isLive     Boolean  @default(false)

  source ScrapingSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  match  Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([sourceId, scrapedAt])
  @@index([matchId])
  @@map("scraped_predictions")
}

model Accumulator {
  id         String   @id @default(cuid())
  userId     String
  name       String?
  totalOdds  Decimal  @db.Decimal(12, 3)
  isAnalyzed Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches  AccumulatorMatch[]
  analyses Analysis[]

  @@index([userId])
  @@map("accumulators")
}

model AccumulatorMatch {
  id            String @id @default(cuid())
  accumulatorId String
  matchId       String
  betType       String?
  betChoice     String?
  odds          Decimal? @db.Decimal(10, 3)

  accumulator Accumulator @relation(fields: [accumulatorId], references: [id], onDelete: Cascade)
  match       Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([accumulatorId, matchId])
  @@map("accumulator_matches")
}

model SuggestedAccumulator {
  id         String   @id @default(cuid())
  sourceSlug String // predictz | windrawwin | scores24
  title      String
  totalOdds  Decimal  @db.Decimal(12, 3)
  legsJson   Json // [{home, away, league, betChoice, odds}]
  matchDate  DateTime
  createdAt  DateTime @default(now())

  @@index([sourceSlug, matchDate])
  @@map("suggested_accumulators")
}

model Analysis {
  id               String       @id @default(cuid())
  mode             AnalysisMode @default(ACCUMULATOR)
  accumulatorId    String?
  matchId          String?
  userId           String
  iaProvider       AiProvider
  promptUsed       String       @db.LongText
  response         String       @db.LongText
  payload          Json?
  riskScore        Decimal?     @db.Decimal(4, 1)
  evScore          Decimal?     @db.Decimal(8, 3)
  recommendedStake Decimal?     @db.Decimal(4, 1)
  createdAt        DateTime     @default(now())

  accumulator Accumulator? @relation(fields: [accumulatorId], references: [id], onDelete: Cascade)
  match       Match?       @relation(fields: [matchId], references: [id], onDelete: SetNull)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accumulatorId])
  @@index([matchId])
  @@index([userId])
  @@index([mode])
  @@map("analyses")
}

model SessionControl {
  id                   String   @id @default(cuid())
  role                 Role     @unique
  maxSessions          Int      @default(1)
  enforceSingleDevice  Boolean  @default(false)
  updatedAt            DateTime @updatedAt

  @@map("session_controls")
}

model RateLimit {
  id          String   @id @default(cuid())
  identifier  String // userId o IP
  windowStart DateTime
  count       Int      @default(0)

  @@unique([identifier, windowStart])
  @@index([identifier])
  @@map("rate_limits")
}

model SystemLog {
  id        String      @id @default(cuid())
  category  LogCategory
  level     String      @default("info") // info | warn | error
  message   String      @db.Text
  meta      Json?
  userId    String?
  createdAt DateTime    @default(now())

  @@index([category, createdAt])
  @@map("system_logs")
}

/// Caché SWR para históricos RapidAPI / cuotas en tiempo real
model ApiDataCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  provider  String
  payload   Json
  fetchedAt DateTime @default(now())
  staleAt   DateTime
  expiresAt DateTime

  @@index([provider, expiresAt])
  @@map("api_data_cache")
}
