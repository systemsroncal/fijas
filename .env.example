# MySQL remoto en cPanel (NO uses localhost en Vercel/Netlify)
# 1) cPanel → Remote MySQL → añade host "%" (o IPs de Vercel)
# 2) Host = tu dominio o hostname MySQL del hosting (ej. epicdreamsworld.com)
DATABASE_URL="mysql://USER:PASSWORD@epicdreamsworld.com:3306/DB_NAME?connection_limit=5"

# URL pública de la app (Vercel o Netlify)
NEXTAUTH_URL="https://tu-proyecto.vercel.app"
NEXTAUTH_SECRET="cambia-esta-cadena-aleatoria-de-al-menos-32-chars"

# 64 hex chars (32 bytes) AES-256-GCM
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

API_SECRET="cambia-este-secreto-del-scraper"
NODE_ENV="production"

# Vacío = rutas en raíz (recomendado Vercel/Netlify)
# NEXT_PUBLIC_BASE_PATH="/wps-admin"

SEED_ADMIN_EMAIL="admin@epicdreamsworld.com"
SEED_ADMIN_PASSWORD="ChangeMeAdmin123!"

GITHUB_TOKEN=""
GITHUB_REPO="systemsroncal/fijas"
